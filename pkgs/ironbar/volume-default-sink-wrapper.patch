     #[instrument(level = "trace")]
     pub fn set_default_sink(&self, name: &str) {
+        if let Ok(wrapper) = std::env::var("IRONBAR_VOLUME_SET_DEFAULT_SINK")
+            && !wrapper.is_empty()
+        {
+            match Command::new(&wrapper).arg(name).status() {
+                Ok(status) if status.success() => {
+                    return;
+                }
+                Ok(status) => {
+                    error!("default sink wrapper exited with status {status} for {name}");
+                    return;
+                }
+                Err(error) => {
+                    error!("failed to execute default sink wrapper for {name}: {error}");
+                    return;
+                }
+            }
+        }
+
         if let ConnectionState::Connected { context, .. } = &*lock!(self.connection) {
             lock!(context).set_default_sink(name, |_| {});
         }
