#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_SCRIPT="${SCRIPT_DIR}/openclaw-onboard-codex"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'EOF'
Usage: ./scripts/openclaw-onboard-gemini-oauth [extra onboard args...]

This wrapper uses Gemini OAuth defaults and delegates to:
  ./scripts/openclaw-onboard-codex

Default overrides:
  OPENCLAW_AUTH_CHOICE=google-gemini-cli
  OPENCLAW_AUTH_PROVIDER=google-gemini-cli
  OPENCLAW_AUTH_PROFILE=google-gemini-cli:default
  OPENCLAW_SET_DEFAULT_MODEL=0

Notes:
  - If your environment uses another Gemini OAuth method, pass:
      --auth-choice google-antigravity
    or override OPENCLAW_AUTH_CHOICE.
  - Set OPENCLAW_SET_DEFAULT_MODEL=1 and OPENCLAW_DEFAULT_MODEL=<model-id>
    if you also want to switch the default model.
EOF
  exit 0
fi

if [[ ! -x "$BASE_SCRIPT" ]]; then
  echo "Missing executable base script: $BASE_SCRIPT" >&2
  exit 1
fi

OPENCLAW_AUTH_CHOICE="${OPENCLAW_AUTH_CHOICE:-google-gemini-cli}" \
OPENCLAW_AUTH_PROVIDER="${OPENCLAW_AUTH_PROVIDER:-google-gemini-cli}" \
OPENCLAW_AUTH_PROFILE="${OPENCLAW_AUTH_PROFILE:-google-gemini-cli:default}" \
OPENCLAW_SET_DEFAULT_MODEL="${OPENCLAW_SET_DEFAULT_MODEL:-0}" \
exec "$BASE_SCRIPT" "$@"
