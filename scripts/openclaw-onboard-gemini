#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_SCRIPT="${SCRIPT_DIR}/openclaw-onboard-codex"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'EOF'
Usage: ./scripts/openclaw-onboard-gemini [extra onboard args...]

This wrapper uses Gemini auth defaults and delegates to:
  ./scripts/openclaw-onboard-codex

Default overrides:
  OPENCLAW_AUTH_CHOICE=gemini-api-key
  OPENCLAW_AUTH_PROVIDER=gemini-api-key
  OPENCLAW_AUTH_PROFILE=gemini-api-key:default
  OPENCLAW_SET_DEFAULT_MODEL=0

Notes:
  - Pass --auth-choice explicitly to override auth flow.
  - Set OPENCLAW_SET_DEFAULT_MODEL=1 and OPENCLAW_DEFAULT_MODEL=<model-id>
    if you also want to switch default model.
EOF
  exit 0
fi

if [[ ! -x "$BASE_SCRIPT" ]]; then
  echo "Missing executable base script: $BASE_SCRIPT" >&2
  exit 1
fi

OPENCLAW_AUTH_CHOICE="${OPENCLAW_AUTH_CHOICE:-gemini-api-key}" \
OPENCLAW_AUTH_PROVIDER="${OPENCLAW_AUTH_PROVIDER:-gemini-api-key}" \
OPENCLAW_AUTH_PROFILE="${OPENCLAW_AUTH_PROFILE:-gemini-api-key:default}" \
OPENCLAW_SET_DEFAULT_MODEL="${OPENCLAW_SET_DEFAULT_MODEL:-0}" \
exec "$BASE_SCRIPT" "$@"
