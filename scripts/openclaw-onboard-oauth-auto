#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import pty
import re
import shlex
import signal
import subprocess
import sys
import threading
import time
from pathlib import Path
from typing import Any

ANSI_ESCAPE_RE = re.compile(r"\x1B\[[0-?]*[ -/]*[@-~]")
URL_RE = re.compile(r"https?://[^\s\"'<>]+")
CODE_RE = re.compile(r"\b(\d{6})\b")
URL_HINTS = ("oauth", "authorize", "code_challenge", "redirect_uri", "response_type")

DEFAULT_SELECTORS: dict[str, list[str]] = {
  "email": [
    "input[type='email']",
    "input[name='email']",
    "input[name='username']",
    "input[autocomplete='username']",
    "input#email",
  ],
  "password": [
    "input[type='password']",
    "input[name='password']",
    "input[autocomplete='current-password']",
  ],
  "code": [
    "input[inputmode='numeric']",
    "input[autocomplete='one-time-code']",
    "input[name*='code' i]",
    "input[id*='code' i]",
  ],
  "submit": [
    "button[type='submit']",
    "button:has-text('Continue')",
    "button:has-text('Verify')",
    "button:has-text('Sign in')",
    "button:has-text('Next')",
    "input[type='submit']",
  ],
  "refresh": [
    "button:has-text('Refresh')",
    "button[aria-label*='Refresh' i]",
    "[data-testid*='refresh' i]",
  ],
}

VERBOSE = False


def eprint(message: str) -> None:
  print(message, file=sys.stderr, flush=True)


def vlog(message: str) -> None:
  if VERBOSE:
    eprint(f"[verbose] {message}")


def decode_wait_status(status: int) -> int:
  if os.WIFEXITED(status):
    return os.WEXITSTATUS(status)
  if os.WIFSIGNALED(status):
    return 128 + os.WTERMSIG(status)
  return 1


class OnboardSession:
  def __init__(self, cmd: list[str]) -> None:
    self.cmd = cmd
    self.pid: int | None = None
    self.fd: int | None = None
    self._reader: threading.Thread | None = None
    self._exit_status: int | None = None
    self._lock = threading.Lock()
    self._scan_buffer = ""
    self._seen_urls: set[str] = set()
    self._first_url: str | None = None
    self._first_seen_at: float | None = None
    self._preferred_url: str | None = None

  def start(self) -> None:
    if not self.cmd:
      raise RuntimeError("onboard command is empty")

    pid, fd = pty.fork()
    if pid == 0:
      try:
        os.execvp(self.cmd[0], self.cmd)
      except Exception as exc:
        print(f"Failed to exec onboard command: {exc}", file=sys.stderr)
      os._exit(127)

    self.pid = pid
    self.fd = fd
    self._reader = threading.Thread(target=self._reader_loop, daemon=True)
    self._reader.start()

  def _reader_loop(self) -> None:
    if self.fd is None:
      return

    while True:
      try:
        chunk = os.read(self.fd, 4096)
      except OSError:
        break

      if not chunk:
        break

      text = chunk.decode("utf-8", errors="replace")
      sys.stdout.write(text)
      sys.stdout.flush()
      self._capture_urls(text)

    self._poll_exit()

  def _capture_urls(self, text: str) -> None:
    cleaned = ANSI_ESCAPE_RE.sub("", text)
    with self._lock:
      self._scan_buffer = (self._scan_buffer + cleaned)[-32768:]
      for match in URL_RE.finditer(self._scan_buffer):
        candidate = match.group(0).rstrip("),.;")
        if candidate in self._seen_urls:
          continue
        self._seen_urls.add(candidate)
        if self._first_url is None:
          self._first_url = candidate
          self._first_seen_at = time.monotonic()
        lowered = candidate.lower()
        if self._preferred_url is None and any(hint in lowered for hint in URL_HINTS):
          self._preferred_url = candidate
          vlog(f"preferred auth URL detected: {candidate}")

  def _poll_exit(self) -> int | None:
    if self.pid is None:
      return self._exit_status
    if self._exit_status is not None:
      return self._exit_status
    try:
      waited_pid, status = os.waitpid(self.pid, os.WNOHANG)
    except ChildProcessError:
      self._exit_status = 0
      return self._exit_status
    if waited_pid == self.pid:
      self._exit_status = status
    return self._exit_status

  def wait_for_auth_url(self, timeout_sec: int) -> str:
    deadline = time.monotonic() + timeout_sec
    while time.monotonic() < deadline:
      with self._lock:
        preferred = self._preferred_url
        first = self._first_url
        first_seen_at = self._first_seen_at

      if preferred:
        return preferred
      if first and first_seen_at and (time.monotonic() - first_seen_at) >= 0.7:
        return first

      if self._poll_exit() is not None:
        break
      time.sleep(0.1)

    with self._lock:
      if self._preferred_url:
        return self._preferred_url
      if self._first_url:
        return self._first_url

    raise RuntimeError("onboard 出力から認証URLを抽出できませんでした。")

  def send_line(self, line: str) -> None:
    if self.fd is None:
      raise RuntimeError("onboard session is not started")
    payload = line if line.endswith("\n") else f"{line}\n"
    os.write(self.fd, payload.encode("utf-8", errors="ignore"))

  def wait(self) -> int:
    if self.pid is None:
      return 1
    if self._exit_status is None:
      try:
        _, status = os.waitpid(self.pid, 0)
        self._exit_status = status
      except ChildProcessError:
        self._exit_status = 0
    if self._reader is not None:
      self._reader.join(timeout=1.0)
    return decode_wait_status(self._exit_status)

  def terminate(self) -> None:
    if self.pid is None:
      return
    if self._exit_status is not None:
      return
    try:
      os.kill(self.pid, signal.SIGTERM)
    except ProcessLookupError:
      return
    except Exception:
      return
    try:
      _, status = os.waitpid(self.pid, 0)
      self._exit_status = status
    except Exception:
      return


def list_or_str(values: Any) -> list[str]:
  if isinstance(values, str):
    return [values]
  if isinstance(values, list):
    return [item for item in values if isinstance(item, str)]
  return []


def merged_selectors(profile: dict[str, Any], key: str) -> list[str]:
  custom = []
  selectors = profile.get("selectors")
  if isinstance(selectors, dict):
    custom = list_or_str(selectors.get(key))
  defaults = DEFAULT_SELECTORS.get(key, [])
  merged = custom[:]
  for selector in defaults:
    if selector not in merged:
      merged.append(selector)
  return merged


def load_profile(path: Path, name: str) -> dict[str, Any]:
  if not path.exists():
    raise RuntimeError(f"profiles file not found: {path}")
  try:
    data = json.loads(path.read_text(encoding="utf-8"))
  except json.JSONDecodeError as exc:
    raise RuntimeError(f"profiles JSON parse error: {exc}") from exc

  profiles = data.get("profiles")
  if not isinstance(profiles, dict):
    raise RuntimeError("profiles JSON must contain object key: profiles")

  profile = profiles.get(name)
  if not isinstance(profile, dict):
    raise RuntimeError(f"profile not found: {name}")

  return profile


def run_secret_command(command: str) -> str:
  completed = subprocess.run(
    ["bash", "-lc", command],
    capture_output=True,
    text=True,
    check=False,
  )
  if completed.returncode != 0:
    stderr = (completed.stderr or "").strip()
    raise RuntimeError(f"passwordCommand failed: {stderr or 'exit code ' + str(completed.returncode)}")
  lines = [line.strip() for line in completed.stdout.splitlines() if line.strip()]
  if not lines:
    raise RuntimeError("passwordCommand returned empty output")
  return lines[0]


def import_playwright() -> tuple[Any, Any]:
  try:
    from playwright.sync_api import TimeoutError as PlaywrightTimeoutError
    from playwright.sync_api import sync_playwright
  except Exception as exc:
    raise RuntimeError(
      "playwright の import に失敗しました。`nix develop .#py312` から実行してください。"
    ) from exc
  return sync_playwright, PlaywrightTimeoutError


def try_find_visible_field(context: Any, selectors: list[str], timeout_sec: float) -> tuple[Any, Any, str] | None:
  deadline = time.monotonic() + timeout_sec
  while time.monotonic() < deadline:
    pages = list(reversed(context.pages))
    for page in pages:
      for selector in selectors:
        try:
          locator = page.locator(selector).first
          if locator.count() < 1:
            continue
          locator.wait_for(state="visible", timeout=300)
          return page, locator, selector
        except Exception:
          continue
    time.sleep(0.2)
  return None


def try_click_submit(page: Any, selectors: list[str]) -> bool:
  for selector in selectors:
    try:
      locator = page.locator(selector).first
      if locator.count() < 1:
        continue
      locator.click(timeout=1000)
      return True
    except Exception:
      continue
  try:
    page.keyboard.press("Enter")
    return True
  except Exception:
    return False


def wait_for_redirect_url(context: Any, match_text: str, timeout_sec: int) -> str | None:
  deadline = time.monotonic() + timeout_sec
  while time.monotonic() < deadline:
    for page in reversed(context.pages):
      url = page.url or ""
      if match_text in url:
        return url
    time.sleep(0.2)
  return None


def extract_code(text: str) -> str | None:
  matches = list(CODE_RE.finditer(text))
  if not matches:
    return None
  scored: list[tuple[int, int, str]] = []
  for index, match in enumerate(matches):
    start = max(0, match.start() - 48)
    end = min(len(text), match.end() + 48)
    window = text[start:end].lower()
    score = 0
    if any(word in window for word in ("verification", "verify", "one-time", "otp", "code", "認証", "ワンタイム")):
      score = 1
    scored.append((score, -index, match.group(1)))
  scored.sort(reverse=True)
  return scored[0][2]


def extract_code_from_selectors(page: Any, selectors: list[str]) -> str | None:
  for selector in selectors:
    try:
      locator = page.locator(selector)
      count = min(locator.count(), 8)
      for index in range(count):
        text = locator.nth(index).inner_text(timeout=800)
        code = extract_code(text)
        if code:
          return code
    except Exception:
      continue
  return None


def extract_code_from_page(page: Any) -> str | None:
  text_parts: list[str] = []
  try:
    text_parts.append(page.inner_text("body", timeout=2000))
  except Exception:
    pass
  for frame in page.frames:
    try:
      text_parts.append(frame.inner_text("body", timeout=700))
    except Exception:
      continue
  return extract_code("\n".join(text_parts))


def maybe_click_refresh(page: Any, selectors: list[str]) -> None:
  for selector in selectors:
    try:
      locator = page.locator(selector).first
      if locator.count() < 1:
        continue
      locator.click(timeout=600)
      return
    except Exception:
      continue


def fetch_code_from_source_page(
  context: Any,
  source_url: str,
  timeout_sec: int,
  code_selectors: list[str],
  refresh_selectors: list[str],
) -> str | None:
  page = context.new_page()
  try:
    page.goto(source_url, wait_until="domcontentloaded", timeout=60000)
  except Exception as exc:
    page.close()
    raise RuntimeError(f"認証コード取得ページを開けませんでした: {source_url} ({exc})") from exc

  deadline = time.monotonic() + timeout_sec
  next_reload = 0.0
  try:
    while time.monotonic() < deadline:
      code = None
      if code_selectors:
        code = extract_code_from_selectors(page, code_selectors)
      if not code:
        code = extract_code_from_page(page)
      if code:
        return code

      maybe_click_refresh(page, refresh_selectors)
      now = time.monotonic()
      if now >= next_reload:
        try:
          page.reload(wait_until="domcontentloaded", timeout=20000)
        except Exception:
          pass
        next_reload = now + 4.0
      page.wait_for_timeout(900)
  finally:
    page.close()
  return None


def read_manual_code(prompt: str) -> str | None:
  try:
    value = input(prompt).strip()
  except EOFError:
    return None
  return value or None


def resolve_verification_code(context: Any, profile: dict[str, Any], timeout_sec: int, manual_fallback: bool) -> str:
  mode = str(profile.get("verificationMode", "none")).strip().lower()
  if mode in {"", "none"}:
    if manual_fallback:
      value = read_manual_code("認証コードを手入力してください: ")
      if value:
        return value
    raise RuntimeError("verificationMode が未設定のため認証コードを解決できません。")

  if mode == "getotp":
    source_url = str(profile.get("otpPageUrl", "")).strip()
    code_selectors = list_or_str(profile.get("otpCodeSelectors"))
    refresh_selectors = list_or_str(profile.get("otpRefreshSelectors")) or DEFAULT_SELECTORS["refresh"]
  elif mode == "tinyhost-mail":
    source_url = str(profile.get("mailboxUrl", "")).strip()
    code_selectors = list_or_str(profile.get("mailCodeSelectors"))
    refresh_selectors = list_or_str(profile.get("mailRefreshSelectors")) or DEFAULT_SELECTORS["refresh"]
  else:
    raise RuntimeError(f"unsupported verificationMode: {mode}")

  if not source_url:
    raise RuntimeError(f"{mode} に必要なURL設定が不足しています。")

  code = fetch_code_from_source_page(
    context=context,
    source_url=source_url,
    timeout_sec=timeout_sec,
    code_selectors=code_selectors,
    refresh_selectors=refresh_selectors,
  )
  if code:
    return code

  if manual_fallback:
    value = read_manual_code("認証コードを手入力してください: ")
    if value:
      return value

  raise RuntimeError(f"認証コードの取得に失敗しました (mode={mode})")


def automate_oauth(
  auth_url: str,
  profile: dict[str, Any],
  timeout_sec: int,
  headless: bool,
  manual_fallback: bool,
) -> str:
  sync_playwright, playwright_timeout_error = import_playwright()
  redirect_match = str(profile.get("localhostMatch", "localhost")).strip() or "localhost"

  email_selectors = merged_selectors(profile, "email")
  password_selectors = merged_selectors(profile, "password")
  code_selectors = merged_selectors(profile, "code")
  submit_selectors = merged_selectors(profile, "submit")

  username = str(profile.get("username", "")).strip()
  password_command = str(profile.get("passwordCommand", "")).strip()

  with sync_playwright() as playwright:
    browser = playwright.chromium.launch(headless=headless)
    context = browser.new_context()
    page = context.new_page()

    try:
      page.goto(auth_url, wait_until="domcontentloaded", timeout=60000)
    except playwright_timeout_error:
      if not manual_fallback:
        browser.close()
        raise RuntimeError("認証ページの読み込みがタイムアウトしました。")
    except Exception as exc:
      if not manual_fallback:
        browser.close()
        raise RuntimeError(f"認証ページの読み込みに失敗しました: {exc}") from exc
      vlog(f"initial page.goto failed but continuing with manual fallback: {exc}")

    immediate = wait_for_redirect_url(context, redirect_match, 2)
    if immediate:
      browser.close()
      return immediate

    if username:
      email_target = try_find_visible_field(context, email_selectors, 20)
      if email_target:
        email_page, email_locator, used_selector = email_target
        vlog(f"email selector used: {used_selector}")
        email_locator.fill(username)
        try_click_submit(email_page, submit_selectors)
      elif not manual_fallback:
        browser.close()
        raise RuntimeError("メールアドレス入力欄が見つかりませんでした。")

    if password_command:
      password = run_secret_command(password_command)
      password_target = try_find_visible_field(context, password_selectors, 25)
      if password_target:
        password_page, password_locator, used_selector = password_target
        vlog(f"password selector used: {used_selector}")
        password_locator.fill(password)
        try_click_submit(password_page, submit_selectors)
      elif not manual_fallback:
        browser.close()
        raise RuntimeError("パスワード入力欄が見つかりませんでした。")
    elif not manual_fallback:
      browser.close()
      raise RuntimeError("passwordCommand が未設定です。")

    code_target = try_find_visible_field(context, code_selectors, 10)
    if code_target:
      code = resolve_verification_code(context, profile, timeout_sec, manual_fallback)
      refreshed_code_target = try_find_visible_field(context, code_selectors, 8) or code_target
      code_page, code_locator, used_selector = refreshed_code_target
      vlog(f"code selector used: {used_selector}")
      code_locator.fill(code)
      try_click_submit(code_page, submit_selectors)

    redirect_url = wait_for_redirect_url(context, redirect_match, timeout_sec)
    if redirect_url:
      browser.close()
      return redirect_url

    if manual_fallback:
      eprint("自動操作で完了しなかったため、手動介入モードに移行します。")
      eprint(f"{timeout_sec}秒以内にブラウザで認証を完了してください。")
      redirect_url = wait_for_redirect_url(context, redirect_match, timeout_sec)
      if redirect_url:
        browser.close()
        return redirect_url

    browser.close()
    raise RuntimeError(f"{redirect_match} を含むリダイレクトURLを取得できませんでした。")


def build_onboard_command(onboard_cmd: str | None, onboard_args: list[str]) -> list[str]:
  if onboard_cmd:
    cmd = shlex.split(onboard_cmd)
  else:
    default_script = Path(__file__).resolve().with_name("openclaw-onboard-codex")
    if not default_script.exists():
      raise RuntimeError(
        f"default onboard script not found: {default_script} (use --onboard-cmd)"
      )
    cmd = [str(default_script)]

  forwarded = onboard_args[:]
  if forwarded and forwarded[0] == "--":
    forwarded = forwarded[1:]

  return cmd + forwarded


def parse_args() -> argparse.Namespace:
  parser = argparse.ArgumentParser(
    description="openclaw onboard の認証URLを自動処理し、リダイレクトURLを返入力します。"
  )
  parser.add_argument("--profile", required=True, help="profiles.json のプロファイル名")
  parser.add_argument(
    "--profiles-file",
    default="~/.config/oauth-auto/profiles.json",
    help="プロファイルJSONのパス",
  )
  parser.add_argument(
    "--timeout-sec",
    type=int,
    default=90,
    help="認証コード取得とリダイレクト待機のタイムアウト秒",
  )
  parser.add_argument(
    "--onboard-url-timeout-sec",
    type=int,
    default=120,
    help="onboard出力から認証URLを待つ最大秒数",
  )
  parser.add_argument("--onboard-cmd", help="起動する onboard コマンド文字列")
  parser.add_argument("--headless", action="store_true", help="Playwrightをヘッドレスで起動")
  parser.add_argument(
    "--manual-fallback",
    action=argparse.BooleanOptionalAction,
    default=True,
    help="自動操作失敗時に手動操作へフォールバックする",
  )
  parser.add_argument(
    "--print-redirect-url",
    action="store_true",
    help="取得したリダイレクトURLを標準出力へ出力する",
  )
  parser.add_argument(
    "--verbose",
    action=argparse.BooleanOptionalAction,
    default=False,
    help="詳細ログを stderr へ出力する",
  )
  parser.add_argument(
    "onboard_args",
    nargs=argparse.REMAINDER,
    help="`--` 以降は onboard コマンドへそのまま渡す",
  )
  return parser.parse_args()


def main() -> int:
  global VERBOSE
  args = parse_args()
  VERBOSE = args.verbose

  session: OnboardSession | None = None

  try:
    profile_path = Path(os.path.expanduser(args.profiles_file)).resolve()
    profile = load_profile(profile_path, args.profile)
    onboard_command = build_onboard_command(args.onboard_cmd, args.onboard_args)

    vlog(f"profile file: {profile_path}")
    vlog("onboard command: " + " ".join(shlex.quote(x) for x in onboard_command))

    session = OnboardSession(onboard_command)
    session.start()

    auth_url = session.wait_for_auth_url(args.onboard_url_timeout_sec)
    eprint(f"認証URLを検出: {auth_url}")

    redirect_url = automate_oauth(
      auth_url=auth_url,
      profile=profile,
      timeout_sec=args.timeout_sec,
      headless=args.headless,
      manual_fallback=args.manual_fallback,
    )

    eprint(f"リダイレクトURL取得: {redirect_url}")
    if args.print_redirect_url:
      print(redirect_url)
    session.send_line(redirect_url)

    onboard_exit = session.wait()
    if onboard_exit != 0:
      raise RuntimeError(f"onboard が非0で終了しました: {onboard_exit}")
    return 0
  except KeyboardInterrupt:
    eprint("中断します。")
    if session is not None:
      session.terminate()
    return 130
  except Exception as exc:
    eprint(f"エラー: {exc}")
    if session is not None:
      session.terminate()
    return 1


if __name__ == "__main__":
  raise SystemExit(main())
