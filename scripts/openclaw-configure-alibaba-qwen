#!/usr/bin/env bash
set -euo pipefail

CONTAINER="${OPENCLAW_CONTAINER:-openclaw}"
OPENCLAW_PKG="${OPENCLAW_PKG:-openclaw@2026.2.26}"
OPENCLAW_CONFIG_PATH="${OPENCLAW_CONFIG_PATH:-}"
OPENCLAW_SERVICE_UNIT="${OPENCLAW_SERVICE_UNIT:-podman-${CONTAINER}.service}"
OPENCLAW_RESTART_AFTER_APPLY="${OPENCLAW_RESTART_AFTER_APPLY:-1}"
OPENCLAW_SET_DEFAULT_MODEL="${OPENCLAW_SET_DEFAULT_MODEL:-0}"
OPENCLAW_PROVIDER_ID="${OPENCLAW_ALIBABA_PROVIDER_ID:-alibaba-qwen}"
OPENCLAW_REGION="${OPENCLAW_ALIBABA_REGION:-intl}"
OPENCLAW_BASE_URL="${OPENCLAW_ALIBABA_BASE_URL:-}"
OPENCLAW_MODEL_PLUS="${OPENCLAW_ALIBABA_MODEL_PLUS:-qwen3.5-plus}"
OPENCLAW_MODEL_MAX="${OPENCLAW_ALIBABA_MODEL_MAX:-qwen3-max}"
OPENCLAW_MODEL_FALLBACK_PLUS="${OPENCLAW_ALIBABA_MODEL_FALLBACK_PLUS:-qwen-plus}"
OPENCLAW_MODEL_FALLBACK_MAX="${OPENCLAW_ALIBABA_MODEL_FALLBACK_MAX:-qwen-max}"
OPENCLAW_DEFAULT_MODEL="${OPENCLAW_ALIBABA_DEFAULT_MODEL:-${OPENCLAW_PROVIDER_ID}/${OPENCLAW_MODEL_PLUS}}"
OPENCLAW_API_KEY_LITERAL="${OPENCLAW_ALIBABA_API_KEY:-}"
OPENCLAW_API_KEY_REF="${OPENCLAW_ALIBABA_API_KEY_REF:-\${ALIBABA_CODING_PLAN_API_KEY}}"
OPENCLAW_CONTEXT_WINDOW="${OPENCLAW_ALIBABA_CONTEXT_WINDOW:-1000000}"
OPENCLAW_MAX_TOKENS="${OPENCLAW_ALIBABA_MAX_TOKENS:-8192}"
CONTAINER_WAIT_RETRIES="${OPENCLAW_CONTAINER_WAIT_RETRIES:-60}"
CONTAINER_WAIT_SECONDS="${OPENCLAW_CONTAINER_WAIT_SECONDS:-1}"

usage() {
  cat <<'EOF'
Usage: ./scripts/openclaw-configure-alibaba-qwen

Configure Alibaba Cloud Coding Plan (OpenAI-compatible) Qwen models in OpenClaw.

Environment overrides:
  OPENCLAW_CONTAINER             Podman container name (default: openclaw)
  OPENCLAW_PKG                   npx package spec (default: openclaw@2026.2.26)
  OPENCLAW_CONFIG_PATH           explicit openclaw.json path override
  OPENCLAW_SERVICE_UNIT          systemd unit name (default: podman-<container>.service)
  OPENCLAW_RESTART_AFTER_APPLY   restart service/container after config update (default: 1)
  OPENCLAW_SET_DEFAULT_MODEL     run models set after apply (default: 0)

  OPENCLAW_ALIBABA_PROVIDER_ID   provider id in config (default: alibaba-qwen)
  OPENCLAW_ALIBABA_REGION        intl|us|cn|custom (default: intl)
  OPENCLAW_ALIBABA_BASE_URL      explicit base URL (required when region=custom)

  OPENCLAW_ALIBABA_MODEL_PLUS            primary plus model id (default: qwen3.5-plus)
  OPENCLAW_ALIBABA_MODEL_MAX             primary max model id (default: qwen3-max)
  OPENCLAW_ALIBABA_MODEL_FALLBACK_PLUS   fallback plus id (default: qwen-plus)
  OPENCLAW_ALIBABA_MODEL_FALLBACK_MAX    fallback max id (default: qwen-max)
  OPENCLAW_ALIBABA_DEFAULT_MODEL         default model to set when OPENCLAW_SET_DEFAULT_MODEL=1

  OPENCLAW_ALIBABA_API_KEY       literal API key (optional; avoid storing in config)
  OPENCLAW_ALIBABA_API_KEY_REF   env placeholder in config (default: ${ALIBABA_CODING_PLAN_API_KEY})
  OPENCLAW_ALIBABA_CONTEXT_WINDOW contextWindow for injected model defs (default: 1000000)
  OPENCLAW_ALIBABA_MAX_TOKENS     maxTokens for injected model defs (default: 8192)

Notes:
  - Recommended: keep OPENCLAW_ALIBABA_API_KEY unset and provide ALIBABA_CODING_PLAN_API_KEY
    via service environment.
  - Default is Coding Plan endpoint for intl:
      intl -> https://coding-intl.dashscope.aliyuncs.com/v1
  - Non-Coding-Plan endpoints:
      us   -> https://dashscope-us.aliyuncs.com/compatible-mode/v1
      cn   -> https://dashscope.aliyuncs.com/compatible-mode/v1
  - For other endpoints, set OPENCLAW_ALIBABA_BASE_URL explicitly.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if ! command -v podman >/dev/null 2>&1; then
  echo "podman command not found." >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "jq is required." >&2
  exit 1
fi

if ! podman container exists "$CONTAINER"; then
  echo "Container \"$CONTAINER\" does not exist." >&2
  exit 1
fi

if [[ "$(podman inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null || true)" != "true" ]]; then
  echo "Container \"$CONTAINER\" is not running." >&2
  echo "Start it with: systemctl start ${OPENCLAW_SERVICE_UNIT}" >&2
  exit 1
fi

resolve_base_url() {
  if [[ -n "$OPENCLAW_BASE_URL" ]]; then
    printf '%s\n' "$OPENCLAW_BASE_URL"
    return 0
  fi
  case "$OPENCLAW_REGION" in
    intl) printf '%s\n' "https://coding-intl.dashscope.aliyuncs.com/v1" ;;
    us) printf '%s\n' "https://dashscope-us.aliyuncs.com/compatible-mode/v1" ;;
    cn) printf '%s\n' "https://dashscope.aliyuncs.com/compatible-mode/v1" ;;
    custom)
      echo "OPENCLAW_ALIBABA_BASE_URL is required when OPENCLAW_ALIBABA_REGION=custom." >&2
      exit 1
      ;;
    *)
      echo "Unsupported OPENCLAW_ALIBABA_REGION: $OPENCLAW_REGION (use intl|us|cn|custom)" >&2
      exit 1
      ;;
  esac
}

find_openclaw_config() {
  local candidates=()
  if [[ -n "$OPENCLAW_CONFIG_PATH" ]]; then
    candidates+=("$OPENCLAW_CONFIG_PATH")
  fi
  candidates+=(
    "/var/lib/openclaw-rootless/root/.openclaw/openclaw.json"
    "/var/lib/openclaw/root/.openclaw/openclaw.json"
  )

  local path
  for path in "${candidates[@]}"; do
    if [[ -f "$path" ]]; then
      printf '%s\n' "$path"
      return 0
    fi
    if sudo test -f "$path" >/dev/null 2>&1; then
      printf '%s\n' "$path"
      return 0
    fi
  done
  return 1
}

wait_for_container_running() {
  local i
  for ((i = 0; i < CONTAINER_WAIT_RETRIES; i++)); do
    if [[ "$(podman inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null || true)" == "true" ]]; then
      return 0
    fi
    sleep "$CONTAINER_WAIT_SECONDS"
  done
  return 1
}

wait_for_exec_ready() {
  local i
  for ((i = 0; i < CONTAINER_WAIT_RETRIES; i++)); do
    if [[ "$(podman inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null || true)" == "true" ]]; then
      if podman exec "$CONTAINER" sh -lc ':' >/dev/null 2>&1; then
        return 0
      fi
    fi
    sleep "$CONTAINER_WAIT_SECONDS"
  done
  return 1
}

restart_unit_or_container() {
  if [[ "$OPENCLAW_RESTART_AFTER_APPLY" != "1" ]]; then
    return 0
  fi

  if systemctl --no-ask-password restart "$OPENCLAW_SERVICE_UNIT" >/dev/null 2>&1; then
    :
  elif sudo -n systemctl restart "$OPENCLAW_SERVICE_UNIT" >/dev/null 2>&1; then
    :
  else
    podman restart "$CONTAINER" >/dev/null
  fi

  if ! wait_for_container_running; then
    echo "Container \"$CONTAINER\" did not become running after restart." >&2
    exit 1
  fi
}

CONFIG_PATH="$(find_openclaw_config || true)"
if [[ -z "$CONFIG_PATH" ]]; then
  echo "openclaw.json not found." >&2
  exit 1
fi

BASE_URL="$(resolve_base_url)"
API_KEY_VALUE="$OPENCLAW_API_KEY_REF"
if [[ -n "$OPENCLAW_API_KEY_LITERAL" ]]; then
  API_KEY_VALUE="$OPENCLAW_API_KEY_LITERAL"
fi

BACKUP_PATH="${CONFIG_PATH}.bak.$(date +%Y%m%d-%H%M%S).before-alibaba-qwen"
TMP_JSON="$(mktemp)"
trap 'rm -f "$TMP_JSON"' EXIT

JQ_FILTER='
  .models.providers = (.models.providers // {})
  | .models.providers[$provider] = (
      ((.models.providers[$provider] // {}) + {
        baseUrl: $baseUrl,
        apiKey: $apiKey,
        api: "openai-completions"
      })
      | .models = (
          ((.models // []) + [
            {
              id: $plus,
              name: "Alibaba Qwen Plus",
              reasoning: false,
              input: ["text"],
              cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
              contextWindow: ($ctx|tonumber),
              maxTokens: ($maxTokens|tonumber)
            },
            {
              id: $max,
              name: "Alibaba Qwen Max",
              reasoning: true,
              input: ["text"],
              cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
              contextWindow: ($ctx|tonumber),
              maxTokens: ($maxTokens|tonumber)
            },
            {
              id: $fallbackPlus,
              name: "Alibaba Qwen Plus (Fallback ID)",
              reasoning: false,
              input: ["text"],
              cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
              contextWindow: ($ctx|tonumber),
              maxTokens: ($maxTokens|tonumber)
            },
            {
              id: $fallbackMax,
              name: "Alibaba Qwen Max (Fallback ID)",
              reasoning: true,
              input: ["text"],
              cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
              contextWindow: ($ctx|tonumber),
              maxTokens: ($maxTokens|tonumber)
            }
          ])
          | map(select(.id != ""))
          | unique_by(.id)
        )
    )
  | .agents.defaults.models = (.agents.defaults.models // {})
  | .agents.defaults.models[($provider + "/" + $plus)] = (.agents.defaults.models[($provider + "/" + $plus)] // {})
  | .agents.defaults.models[($provider + "/" + $max)] = (.agents.defaults.models[($provider + "/" + $max)] // {})
  | .agents.defaults.models[($provider + "/" + $fallbackPlus)] = (.agents.defaults.models[($provider + "/" + $fallbackPlus)] // {})
  | .agents.defaults.models[($provider + "/" + $fallbackMax)] = (.agents.defaults.models[($provider + "/" + $fallbackMax)] // {})
'

if [[ -w "$CONFIG_PATH" ]]; then
  cp -a "$CONFIG_PATH" "$BACKUP_PATH"
  jq \
    --arg provider "$OPENCLAW_PROVIDER_ID" \
    --arg baseUrl "$BASE_URL" \
    --arg apiKey "$API_KEY_VALUE" \
    --arg plus "$OPENCLAW_MODEL_PLUS" \
    --arg max "$OPENCLAW_MODEL_MAX" \
    --arg fallbackPlus "$OPENCLAW_MODEL_FALLBACK_PLUS" \
    --arg fallbackMax "$OPENCLAW_MODEL_FALLBACK_MAX" \
    --arg ctx "$OPENCLAW_CONTEXT_WINDOW" \
    --arg maxTokens "$OPENCLAW_MAX_TOKENS" \
    "$JQ_FILTER" "$CONFIG_PATH" > "$TMP_JSON"
  mv "$TMP_JSON" "$CONFIG_PATH"
else
  sudo cp -a "$CONFIG_PATH" "$BACKUP_PATH"
  sudo jq \
    --arg provider "$OPENCLAW_PROVIDER_ID" \
    --arg baseUrl "$BASE_URL" \
    --arg apiKey "$API_KEY_VALUE" \
    --arg plus "$OPENCLAW_MODEL_PLUS" \
    --arg max "$OPENCLAW_MODEL_MAX" \
    --arg fallbackPlus "$OPENCLAW_MODEL_FALLBACK_PLUS" \
    --arg fallbackMax "$OPENCLAW_MODEL_FALLBACK_MAX" \
    --arg ctx "$OPENCLAW_CONTEXT_WINDOW" \
    --arg maxTokens "$OPENCLAW_MAX_TOKENS" \
    "$JQ_FILTER" "$CONFIG_PATH" > "$TMP_JSON"
  sudo mv "$TMP_JSON" "$CONFIG_PATH"
  sudo chown --reference="$BACKUP_PATH" "$CONFIG_PATH"
  sudo chmod --reference="$BACKUP_PATH" "$CONFIG_PATH"
fi

trap - EXIT
rm -f "$TMP_JSON"

echo "Configured provider: ${OPENCLAW_PROVIDER_ID}"
echo "Base URL: ${BASE_URL}"
echo "Config backup: ${BACKUP_PATH}"

restart_unit_or_container

if ! wait_for_exec_ready; then
  echo "Container \"$CONTAINER\" is not ready for podman exec." >&2
  exit 1
fi

if [[ "$OPENCLAW_SET_DEFAULT_MODEL" == "1" ]]; then
  podman exec "$CONTAINER" npx -y "$OPENCLAW_PKG" models set "$OPENCLAW_DEFAULT_MODEL"
fi

if command -v jq >/dev/null 2>&1; then
  podman exec "$CONTAINER" \
    npx -y "$OPENCLAW_PKG" models status --json | jq \
      '{defaultModel, resolvedDefault, allowed: (.allowed | map(select(startswith("'"$OPENCLAW_PROVIDER_ID"'/"))))}'
fi
