#!/usr/bin/env bash
set -euo pipefail

if (( $# < 1 )); then
  printf 'usage: %s STORE_PATH [VULNIX_ARGS...]\n' "$(basename "$0")" >&2
  exit 2
fi

store_path=$1
shift

real_nix_store=$(command -v nix-store)
vulnix_bin=$(command -v vulnix)
vulnix_cmd=$vulnix_bin
vulnix_wrapped=$(dirname "$vulnix_bin")/.vulnix-wrapped
if [[ -x "$vulnix_wrapped" ]]; then
  vulnix_cmd=$vulnix_wrapped
fi

wrapper_dir=$(mktemp -d)

cleanup() {
  rm -rf "$wrapper_dir"
}
trap cleanup EXIT

cat >"$wrapper_dir/nix-store" <<EOF
#!/usr/bin/env bash
set -euo pipefail

real_nix_store=${real_nix_store@Q}

if [[ "\${1:-}" == "-qd" && \$# -eq 2 ]]; then
  path="\$2"
  deriver="\$("\$real_nix_store" -qd "\$path" 2>/dev/null || true)"

  if [[ -n "\$deriver" && "\$deriver" != "unknown-deriver" && -e "\$deriver" ]]; then
    printf '%s\n' "\$deriver"
    exit 0
  fi

  valid="\$("\$real_nix_store" --query --valid-derivers "\$path" 2>/dev/null | sed -n '1p' || true)"
  if [[ -n "\$valid" && -e "\$valid" ]]; then
    printf '%s\n' "\$valid"
    exit 0
  fi

  if [[ -n "\$deriver" ]]; then
    printf '%s\n' "\$deriver"
    exit 0
  fi
fi

exec "\$real_nix_store" "\$@"
EOF

chmod +x "$wrapper_dir/nix-store"

PATH="$wrapper_dir:$PATH" exec "$vulnix_cmd" -C "$store_path" "$@"
